#!/bin/bash
# /usr/local/bin/deploy-train
# Runs as root (via sudo) during GitHub Actions deployments.
#
# To update this script on the server, include scripts/deploy-train in the SCP
# bundle - it will self-update and re-exec before doing anything else.

set -e

DEPLOY_SRC="${1:-/tmp/train-deploy}"
DEPLOY_DIR=/var/www/train

# Self-update: if the bundle contains a newer version of this script, install
# it and re-exec so the rest of the deployment runs with the updated logic.
BUNDLE_SCRIPT="$DEPLOY_SRC/scripts/deploy-train"
if [ -f "$BUNDLE_SCRIPT" ] && ! diff -q /usr/local/bin/deploy-train "$BUNDLE_SCRIPT" > /dev/null 2>&1; then
    echo "[deploy] Updating deploy script from bundle..."
    install -m 755 "$BUNDLE_SCRIPT" /usr/local/bin/deploy-train
    exec /usr/local/bin/deploy-train "$@"
fi

# Read the service owner from the installed unit - no hardcoded username.
SERVICE_USER=$(systemctl show train --property=User --value)
SERVICE_GROUP=$(systemctl show train --property=Group --value)

if [ -z "$SERVICE_USER" ]; then
    echo "[deploy] ERROR: Could not read User from train.service"
    exit 1
fi

echo "[deploy] Stopping service..."
systemctl stop train || true

echo "[deploy] Installing binary to $DEPLOY_DIR/train (owner: $SERVICE_USER:$SERVICE_GROUP)..."
rm -f "$DEPLOY_DIR/train"
cp "$DEPLOY_SRC/train" "$DEPLOY_DIR/train"
chmod +x "$DEPLOY_DIR/train"

echo "[deploy] Updating web assets..."
rm -rf "$DEPLOY_DIR/templates"
cp -r "$DEPLOY_SRC/templates/" "$DEPLOY_DIR/"
cp -r "$DEPLOY_SRC/static/"    "$DEPLOY_DIR/"
chown -R "$SERVICE_USER:$SERVICE_GROUP" "$DEPLOY_DIR"

echo "[deploy] Starting service..."
systemctl start train

echo "[deploy] Verifying service is active..."
for i in 1 2 3 4 5; do
    if systemctl is-active --quiet train; then
        break
    fi
    sleep 1
done
if ! systemctl is-active --quiet train; then
    echo "[deploy] ERROR: Service failed to start. Status:"
    systemctl status train --no-pager --lines=30
    exit 1
fi

echo "[deploy] Cleaning up..."
rm -rf "$DEPLOY_SRC"

echo "[deploy] Done - train is running."
